# ProcuGents Environment Variables
# Get your free API key at https://opencode.ai/settings/api-keys

# Required for AI analysis (optional - will use rule-based fallback)
OPENCODE_API_KEY=

# Optional - fallback providers
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# Optional - PostgreSQL (defaults to SQLite if not set)
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=postgres
POSTGRES_PASSWORD=
POSTGRES_DB=redflag_agents

# Optional - Redis for caching
REDIS_URL=redis://localhost:6379